{
  "name": "@polyphon-ai/js",
  "version": "0.12.0",
  "description": "JavaScript/TypeScript SDK for the Polyphon JSON-RPC API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test-watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "polyphon",
    "ai",
    "sdk",
    "json-rpc",
    "multi-voice"
  ],
  "author": "Corey Daley",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
